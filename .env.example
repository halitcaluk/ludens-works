# Resend — form submissions go through this service
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where form submissions are delivered
CONTACT_TO_EMAIL=info@ludens.works

# Sender address (must be verified in Resend).
# For quick testing before verifying a domain, use: onboarding@resend.dev
# For production, verify ludens.works in Resend and use something like noreply@ludens.works
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Cloudflare Turnstile — bot protection for the contact form
# Create a widget at: https://dash.cloudflare.com/?to=/:account/turnstile
# Use "Invisible" widget mode
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0xAAAAAAAAAAAAAAAAAAAAAA
TURNSTILE_SECRET_KEY=0xBBBBBBBBBBBBBBBBBBBBBB
